# Database Configuration
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/chattermate

# CORS Configuration add backend url to allow cors from frontend
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Firebase Configuration
FIREBASE_CREDENTIALS=app/config/firebase-config.json

# Widget Configuration # prod image remove :3000 port, since frontend is running on port 80
VITE_WIDGET_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Public URL of THIS backend. Self-hosters MUST set this to their domain
# (e.g. https://support.example.com) — the chat widget derives its API/WS URLs
# from it, so if it stays localhost the embedded widget can't reach the backend.
BACKEND_URL=http://localhost:8000

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
CONVERSATION_SECRET_KEY=your_conversation_secret_key_here

# Encryption and Redis
ENCRYPTION_KEY=RFQ4SzhyRTVYdGtsLUxsc25SaDB0QlZpbTdQRmlVRlpsZUlCaFRlU2Vxbz0=
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=development

# S3 Configuration
S3_FILE_STORAGE=false
S3_BUCKET=chattermate-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Jira OAuth Configuration
JIRA_CLIENT_ID=your_jira_client_id_here
JIRA_CLIENT_SECRET=your_jira_client_secret_here
JIRA_REDIRECT_URI=http://localhost:8000/api/jira/callback

SHOPIFY_API_KEY=your_shopify_key
SHOPIFY_API_SECRET=your_shopify_secret
SHOPIFY_API_VERSION=2025-04

# Slack channel — create an app at api.slack.com/apps. The OAuth redirect URI is
# derived from BACKEND_URL, so add {BACKEND_URL}/api/v1/channels/slack/callback
# to the app's Redirect URLs. Without SLACK_SIGNING_SECRET every incoming Slack
# webhook is rejected with a 403, since signature checks fail closed.
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Meta channels (WhatsApp Cloud API, Messenger, Instagram) — create an app at
# developers.facebook.com. META_WEBHOOK_VERIFY_TOKEN is any random string you pick
# and also enter in the App Dashboard webhook config.
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=any_random_string_you_choose
META_GRAPH_VERSION=v21.0
# Only for cloud-hosted one-click onboarding; leave blank for self-hosting.
# META_CONFIG_ID: WhatsApp Embedded Signup. META_MESSENGER_CONFIG_ID: Facebook
# Login for Business, for connecting a Page (Messenger + Instagram DM).
META_CONFIG_ID=
META_MESSENGER_CONFIG_ID=
# Instagram API with Instagram Login (no Facebook Page needed). These are the
# Instagram app id/secret from the app's Instagram product, NOT the Meta ones.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Comma-separated emails allowed to use one-click Meta signup. Empty = everyone.
# Set this while the Meta app is in App Review so the flow can be exercised in
# production without offering customers a login that would fail for them.
SIGNUP_ALLOWED_EMAILS=

VERIFY_SSL_CERTIFICATES=true

# Enhanced Website Knowledge Base Configuration
KB_MAX_DEPTH=5
KB_MAX_LINKS=25
KB_MIN_CONTENT_LENGTH=100
KB_TIMEOUT=30
KB_MAX_RETRIES=3
KB_MAX_WORKERS=5
KB_BATCH_SIZE=5
KB_OPTIMIZE_ON=1000
